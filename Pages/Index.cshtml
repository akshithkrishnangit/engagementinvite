@page
@model IndexModel
@{
    ViewData["Title"] = "Engagement Invitation";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link href="https://fonts.googleapis.com/css2?family=Allura&family=Playfair+Display:wght@400;500&family=Dancing+Script:wght@400;600&display=swap" rel="stylesheet">

    <style>

            body {
                margin: 0;
                padding: 0;
                min-height: 100vh;
                display: flex;
                justify-content: center;
                align-items: center;
                font-family: 'Playfair Display', serif;
                background: linear-gradient(135deg, #fff8f0, #ffffff);
                overflow-x: hidden;
                overflow-y: auto;
            }

            /* 💖 HEARTS */
            .hearts {
                position: fixed;
                width: 100%;
                height: 100%;
                top: 0;
                left: 0;
                pointer-events: none;
                z-index: 0;
            }

                .hearts span {
                    position: absolute;
                    bottom: -50px;
                    color: #ff4d6d;
                    animation: floatUp 8s linear infinite;
                    opacity: 0.6;
                }

            @@keyframes floatUp {
                0% {
                    transform: translateY(0);
                    opacity: 0;
                }

                20% {
                    opacity: 1;
                }

                100% {
                    transform: translateY(-110vh);
                    opacity: 0;
                }
            }

            /* 💎 CARD (FIXED WIDER PROPERLY) */
            .card {
                width: 95%;
                max-width: 850px; /* ✅ REAL FIX */
                background: rgba(255,255,255,0.3);
                backdrop-filter: blur(20px);
                border-radius: 25px;
                text-align: center;
                overflow: hidden;
                position: relative;
                z-index: 2;
                box-shadow: 0 15px 60px rgba(123,15,42,0.25);
                animation: breathe 6s ease-in-out infinite;
            }

            @@keyframes breathe {
                0% {
                    transform: scale(1);
                }

                50% {
                    transform: scale(1.015);
                }

                100% {
                    transform: scale(1);
                }
            }

            /* 🖼️ BIG HERO IMAGE (LIKE YOUR SCREENSHOT STYLE) */
            .card img {
                width: 100%;
                height: 320px;
                object-fit: cover;
            }

            .content {
                padding: 30px 45px;
            }

            /* 💍 HEADER */
            .live-badge {
                display: inline-block;
                padding: 6px 14px;
                font-size: 12px;
                color: #fff;
                background: linear-gradient(45deg, #7b0f2a, #d4af37);
                border-radius: 20px;
                margin-bottom: 12px;
                /* ✨ RESTORED LIVE EFFECT */
                box-shadow: 0 0 10px rgba(212, 175, 55, 0.6);
                animation: glowPulse 1.8s ease-in-out infinite;
            }

            .invite-text {
                font-family: 'Dancing Script', cursive;
                font-size: 25px;
                line-height: 1.8;
                color: #5a1a1a;
                max-width: 700px;
                margin: 0 auto;
            }

            .names {
                font-family: 'Allura', cursive;
                font-size: 36px;
                color: #8B003F;
                font-weight: bold;
                /* ✨ RESTORED FADE IN */
                opacity: 0;
                animation: fadeInNames 2s ease forwards;
            }

            @@keyframes fadeInNames {
                0% {
                    opacity: 0;
                    transform: translateY(20px);
                    filter: blur(4px);
                }

                100% {
                    opacity: 1;
                    transform: translateY(0);
                    filter: blur(0);
                }
            }

            /* 📅 SAVE CARD */
            .save-card {
                margin-top: 28px;
                padding: 18px;
                border-radius: 18px;
                background: linear-gradient(135deg,#D00063,#B00052,#8B003F);
                color: #FFD76A;
                border: 2px solid #D4AF37;
                font-size: 18px;
                line-height: 1.7;
                box-shadow: 0 12px 30px rgba(176,0,82,.25);
            }

                .save-card span {
                    font-size: 18px;
                    font-weight: 600;
                }

            /* ⏳ COUNTDOWN */
            .countdown-wrapper {
                display: flex;
                gap: 12px;
                justify-content: center;
                margin-top: 18px;
                max-width: 700px;
                margin-left: auto;
                margin-right: auto;
            }

            .count-box {
                flex: 1;
            }

            .flip-card {
                font-size: 22px;
                font-weight: bold;
                color: #D00063;
                background: rgba(255,255,255,0.75);
                border-radius: 12px;
                padding: 14px 0;
                box-shadow: 0 0 15px rgba(212,175,55,0.25);
            }

            .flip {
                animation: flipAnim 0.6s ease;
            }

            @@keyframes flipAnim {
                0% {
                    transform: rotateX(0);
                }

                50% {
                    transform: rotateX(90deg);
                }

                100% {
                    transform: rotateX(0);
                }
            }

            .count-box label {
                font-size: 11px;
                color: #d4af37;
                margin-top: 5px;
                display: block;
            }

            /* 📍 VENUE BUTTON FIX */
            .btn {
                display: block;
                margin-top: 15px;
                padding: 12px;
                background: #D00063;
                color: #d4af37;
                font-weight:bold;
                border-radius: 12px;
                text-decoration: none;
                position: relative;
                z-index: 9999; /* 🔥 IMPORTANT FIX */
            }

            /* 💖 HEARTS FIX */
            .hearts {
                position: fixed;
                width: 100%;
                height: 100%;
                top: 0;
                left: 0;
                pointer-events: none !important;
                z-index: 0;
            }

            @@keyframes glowPulse {
                0% {
                    transform: scale(1);
                    box-shadow: 0 0 8px rgba(212, 175, 55, 0.4);
                }

                50% {
                    transform: scale(1.05);
                    box-shadow: 0 0 18px rgba(212, 175, 55, 0.9);
                }

                100% {
                    transform: scale(1);
                    box-shadow: 0 0 8px rgba(212, 175, 55, 0.4);
                }
            }

    </style>
</head>

<body>

    <div class="hearts" id="hearts"></div>

    <div class="card">

        <img src="@Url.Content("~/Images/us.jpeg")" />

        <div class="content">

          

            <div class="invite-text">

                With the blessings of our families,<br />

                We warmly invite you to the<br>
                Engagement Ceremony of<br />

                <span class="names">Akshith Krishnan<br /> &<br /> Sreekala Rameshan</span><br>

                Your presence will make it special.<br>

                With Love 💖

            </div>

            <div class="save-card">
                <span>Sunday, 23rd August 2026</span><br />
                🕙 10:00 AM – 11:45 AM
            </div>

            <div class="countdown-wrapper">

                <div class="count-box"><div class="flip-card" id="days">00</div><label>Days</label></div>
                <div class="count-box"><div class="flip-card" id="hours">00</div><label>Hours</label></div>
                <div class="count-box"><div class="flip-card" id="minutes">00</div><label>Minutes</label></div>
                <div class="count-box"><div class="flip-card" id="seconds">00</div><label>Seconds</label></div>

            </div>

            <a class="btn" href="https://maps.app.goo.gl/kJaGm4EMwUGG6Fvv8">
                📍 View Venue
            </a>

            <audio id="music" loop>
                <source src="/music/music.mp3" type="audio/mpeg" />
            </audio>

        </div>
    </div>

    <script>
            let eventDate = new Date("2026-08-23 10:00:00").getTime();

            function setFlip(id, value) {
                let el = document.getElementById(id);
                let newVal = String(value).padStart(2, '0');

                if (el.innerText !== newVal) {
                    el.classList.remove("flip");
                    void el.offsetWidth;
                    el.innerText = newVal;
                    el.classList.add("flip");
                }
            }

            function updateCountdown() {
                let now = Date.now();
                let gap = eventDate - now;

                setFlip("days", Math.floor(gap / 86400000));
                setFlip("hours", Math.floor((gap % 86400000) / 3600000));
                setFlip("minutes", Math.floor((gap % 3600000) / 60000));
                setFlip("seconds", Math.floor((gap % 60000) / 1000));
            }

            setInterval(updateCountdown, 1000);
            updateCountdown();

            /* HEARTS */
            setInterval(() => {
                let h = document.createElement("span");
                h.innerHTML = "❤";
                h.style.left = Math.random() * 100 + "vw";
                document.getElementById("hearts").appendChild(h);
                setTimeout(() => h.remove(), 8000);
            }, 500);

            /* MUSIC */
            window.addEventListener("click", function () {
                document.getElementById("music").play();
            }, { once: true });

    </script>

</body>
</html>
