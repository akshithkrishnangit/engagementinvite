@page
@model IndexModel
@{
    ViewData["Title"] = "Engagement Invitation";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Engagement Invitation</title>

    <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Playfair+Display&display=swap" rel="stylesheet">

    <style>
            body {
                margin: 0;
                padding: 0;
                font-family: 'Playfair Display', serif;
                min-height: 100vh;
                display: flex;
                justify-content: center;
                align-items: center;
                background: linear-gradient(135deg, #fff8f0, #fff);
                overflow-x: hidden;
                overflow-y: auto;
            }

            /* 💖 FLOATING HEARTS */
            .hearts {
                position: fixed;
                width: 100%;
                height: 100%;
                top: 0;
                left: 0;
                pointer-events: none;
                z-index: 0;
            }

                .hearts span {
                    position: absolute;
                    bottom: -50px;
                    color: #ff4d6d;
                    animation: floatUp 8s linear infinite;
                    opacity: 0.6;
                }

            @@keyframes floatUp {
                0% {
                    transform: translateY(0);
                    opacity: 0;
                }

                20% {
                    opacity: 1;
                }

                100% {
                    transform: translateY(-110vh);
                    opacity: 0;
                }
            }

            /* 💎 CARD */
            .card {
                width: 94%;
                max-width: 420px;
                background: rgba(255,255,255,0.25);
                backdrop-filter: blur(20px);
                -webkit-backdrop-filter: blur(20px);
                border: 1px solid rgba(255,255,255,0.4);
                border-radius: 25px;
                box-shadow: 0 10px 40px rgba(123, 15, 42, 0.25);
                overflow: hidden;
                text-align: center;
                position: relative;
                z-index: 2;
                animation: fadeInUp 1.2s ease;
            }

            @@keyframes fadeInUp {
                from {
                    opacity: 0;
                    transform: translateY(40px) scale(0.95);
                }

                to {
                    opacity: 1;
                    transform: translateY(0) scale(1);
                }
            }

            /* IMAGE */
            .card img {
                width: 100%;
                height: 220px;
                object-fit: cover;
            }

            .content {
                padding: 18px;
            }

            h1 {
                font-family: 'Great Vibes', cursive;
                font-size: 38px;
                color: #7b0f2a;
                margin: 10px 0;
            }

            .heart {
                font-size: 22px;
            }

            .invite-text {
                font-size: 15px;
                line-height: 1.6;
                color: #5a1a1a;
                font-family: 'Great Vibes', cursive;
            }

            /* 💌 SAVE CARD */
            .save-card {
                margin-top: 12px;
                padding: 12px;
                border-radius: 14px;
                background: rgba(255,255,255,0.35);
                backdrop-filter: blur(10px);
                border: 1px solid #d4af37;
                font-weight: bold;
                font-size: 14px;
                color: #7b0f2a;
                animation: popIn 1.2s ease;
            }

                .save-card span {
                    display: block;
                    font-size: 16px;
                    color: #5a1a1a;
                }

            @@keyframes popIn {
                from {
                    transform: scale(0.7);
                    opacity: 0;
                }

                to {
                    transform: scale(1);
                    opacity: 1;
                }
            }

            /* ⏳ COUNTDOWN */
            .countdown-wrapper {
                display: flex;
                gap: 8px;
                margin-top: 15px;
            }

            .count-box {
                flex: 1;
                perspective: 800px;
            }

                .count-box span {
                    display: block;
                    font-size: 20px;
                    font-weight: bold;
                    color: #7b0f2a;
                    background: rgba(255,255,255,0.6);
                    border-radius: 10px;
                    padding: 10px 0;
                }

                .count-box label {
                    font-size: 11px;
                    color: #d4af37;
                }

            .flip {
                animation: flip 0.6s ease;
            }

            @@keyframes flip {
                0% {
                    transform: rotateX(0);
                }

                50% {
                    transform: rotateX(90deg);
                }

                100% {
                    transform: rotateX(0);
                }
            }

            /* ✨ seconds glow */
            #seconds {
                animation: glow 1s infinite;
            }

            @@keyframes glow {
                0% {
                    box-shadow: 0 0 5px rgba(212,175,55,0.3);
                }

                50% {
                    box-shadow: 0 0 15px rgba(212,175,55,0.8);
                }

                100% {
                    box-shadow: 0 0 5px rgba(212,175,55,0.3);
                }
            }

            /* BUTTON */
            .btn {
                display: block;
                width: 100%;
                margin-top: 10px;
                padding: 12px;
                background: #7b0f2a;
                color: #d4af37;
                border-radius: 12px;
                border: 1px solid #d4af37;
                font-weight: bold;
            }

            /* 🎆 BURST */
            #burstContainer {
                position: fixed;
                width: 100%;
                height: 100%;
                pointer-events: none;
                z-index: 9999;
            }

            .burst {
                position: absolute;
                animation: explode 1.5s ease-out forwards;
            }

            @@keyframes explode {
                0% {
                    transform: scale(0.5);
                    opacity: 1;
                }

                100% {
                    transform: scale(2);
                    opacity: 0;
                }
            }

            .invite-text {
                font-family: 'Parisienne', cursive;
                font-size: 16px;
                line-height: 1.7;
                color: #5a1a1a;
                text-align: center;
            }

            /* 💍 Bold cursive for names */
            .names {
                font-family: 'Great Vibes', cursive;
                font-size: 26px;
                font-weight: bold;
                color: #7b0f2a;
                display: inline-block;
                margin: 8px 0;
            }

            .card {
                animation: breathe 6s ease-in-out infinite;
            }

            @@keyframes breathe {
                0% {
                    transform: scale(1);
                }

                50% {
                    transform: scale(1.015);
                }

                100% {
                    transform: scale(1);
                }
            }

            .card {
                box-shadow: 0 10px 40px rgba(123, 15, 42, 0.25);
                animation: breathe 6s ease-in-out infinite, shadowGlow 6s ease-in-out infinite;
            }

            @@keyframes shadowGlow {
                0% {
                    box-shadow: 0 10px 30px rgba(123, 15, 42, 0.20);
                }

                50% {
                    box-shadow: 0 15px 50px rgba(212, 175, 55, 0.30);
                }

                100% {
                    box-shadow: 0 10px 30px rgba(123, 15, 42, 0.20);
                }
            }

            .card {
                will-change: transform;
                transform-origin: center;
            }

    </style>
</head>

<body>
    
    <div class="hearts" id="hearts"></div>
    <div id="burstContainer"></div>

    <div class="card">

        <img src="@Url.Content("~/Images/us.jpeg")" />

        <div class="content">

            <h1>Engagement Invitation</h1>

            <div class="invite-text">

                With blessings of our families,<br><br>

                We warmly invite you to the<br>
                Engagement Ceremony of<br><br>

                <span class="names">💍 Akshith & Sreekala 💍</span><br><br>

                Your presence will mean a lot to us<br>
                as we begin this beautiful journey 💖<br><br>

                With love.....

            </div>

            <div class="save-card">
                <span>23rd August 2026</span>
                🕙 10:00 AM – 11:45 AM
            </div>

            <div class="countdown-wrapper">
                <div class="count-box"><span id="days">00</span><label>Days</label></div>
                <div class="count-box"><span id="hours">00</span><label>Hours</label></div>
                <div class="count-box"><span id="minutes">00</span><label>Min</label></div>
                <div class="count-box"><span id="seconds">00</span><label>Sec</label></div>
            </div>

            <a class="btn" href="https://maps.app.goo.gl/kJaGm4EMwUGG6Fvv8">📍Venue</a>

            <!-- 🎵 MUSIC -->
            <audio id="music" loop>
                <source src="/music/music.mp3" type="audio/mpeg" />
            </audio>

        </div>
    </div>

    <script>
            var eventDate = new Date("2026-08-23 10:00:00").getTime();
            var burstDone = false;

            /* 🎵 AUTO PLAY MUSIC */
            window.addEventListener("load", function () {
                const music = document.getElementById("music");

                let playPromise = music.play();

                if (playPromise !== undefined) {
                    playPromise.then(() => {
                        music.muted = false;
                    }).catch(() => {
                        document.body.addEventListener("click", function () {
                            music.play();
                            music.muted = false;
                        }, { once: true });
                    });
                }
            });

            /* 💖 HEARTS */
            function createHearts() {
                const c = document.getElementById("hearts");
                setInterval(() => {
                    const s = document.createElement("span");
                    s.innerHTML = "❤";
                    s.style.left = Math.random() * 100 + "vw";
                    s.style.fontSize = (10 + Math.random() * 20) + "px";
                    c.appendChild(s);
                    setTimeout(() => s.remove(), 8000);
                }, 500);
            }
            createHearts();

            /* 🎆 BURST */
            function burst() {
                const c = document.getElementById("burstContainer");
                for (let i = 0; i < 40; i++) {
                    let d = document.createElement("div");
                    d.className = "burst";
                    d.innerHTML = ["💥", "✨", "🎉", "💖"][Math.random() * 4 | 0];
                    d.style.left = Math.random() * 100 + "vw";
                    d.style.top = Math.random() * 100 + "vh";
                    c.appendChild(d);
                    setTimeout(() => d.remove(), 1500);
                }
            }

            /* FLIP */
            function flip(el){
                el.classList.remove("flip");
                void el.offsetWidth;
                el.classList.add("flip");
            }

            function setVal(id,val){
                let el=document.getElementById(id);
                let v=String(val).padStart(2,'0');
                if(el.innerText!==v){
                    el.innerText=v;
                    flip(el.parentElement);
                }
            }

            function update(){
                let now=Date.now();
                let gap=eventDate-now;

                if(!burstDone && gap<=0){
                    burst();
                    burstDone=true;
                    return;
                }

                let d=Math.floor(gap/86400000);
                let h=Math.floor(gap%86400000/3600000);
                let m=Math.floor(gap%3600000/60000);
                let s=Math.floor(gap%60000/1000);

                setVal("days",d);
                setVal("hours",h);
                setVal("minutes",m);
                setVal("seconds",s);
            }

            setInterval(update,1000);
            update();
                        window.addEventListener("click", function () {
                document.getElementById("music").play();
            }, { once: true });
    </script>

</body>
</html>