@page
@model IndexModel
@{
    ViewData["Title"] = "Engagement Invitation";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link href="https://fonts.googleapis.com/css2?family=Allura&family=Playfair+Display:wght@400;500&family=Dancing+Script:wght@400;600&display=swap" rel="stylesheet">

    <style>
            body {
                margin: 0;
                padding: 0;
                min-height: 100vh;
                display: flex;
                justify-content: center;
                align-items: center;
                font-family: 'Playfair Display', serif;
                background: linear-gradient(135deg, #fff8f0, #ffffff);
                overflow-x: hidden;
                overflow-y: auto;
            }

            /* 💖 HEARTS */
            .hearts {
                position: fixed;
                width: 100%;
                height: 100%;
                top: 0;
                left: 0;
                pointer-events: none;
                z-index: 0;
            }

                .hearts span {
                    position: absolute;
                    bottom: -50px;
                    color: #ff4d6d;
                    animation: floatUp 8s linear infinite;
                    opacity: 0.6;
                }

            @@keyframes floatUp {
                0% {
                    transform: translateY(0);
                    opacity: 0;
                }

                20% {
                    opacity: 1;
                }

                100% {
                    transform: translateY(-110vh);
                    opacity: 0;
                }
            }

            /* 💎 CARD */
            .card {
                width: 92%;
                max-width: 420px;
                background: rgba(255,255,255,0.3);
                backdrop-filter: blur(20px);
                border-radius: 25px;
                text-align: center;
                overflow: hidden;
                position: relative;
                z-index: 2;
                box-shadow: 0 10px 40px rgba(123,15,42,0.25);
                animation: breathe 6s ease-in-out infinite;
            }

            @@keyframes breathe {
                0% {
                    transform: scale(1);
                }

                50% {
                    transform: scale(1.015);
                }

                100% {
                    transform: scale(1);
                }
            }

            /* ✨ SHIMMER */
            .card::before {
                content: "";
                position: absolute;
                top: -50%;
                left: -50%;
                width: 200%;
                height: 200%;
                background: linear-gradient(120deg, transparent, rgba(255,255,255,0.3), transparent);
                transform: rotate(25deg);
                animation: shimmer 6s infinite;
            }

            @@keyframes shimmer {
                0% {
                    transform: translateX(-100%) rotate(25deg);
                }

                100% {
                    transform: translateX(100%) rotate(25deg);
                }
            }

            .card img {
                width: 100%;
                height: 220px;
                object-fit: cover;
            }

            .content {
                padding: 18px;
            }

            /* 💍 HEADER */
            .invite-heading {
                font-family: 'Dancing Script', cursive;
                font-size: 34px;
                color: #7b0f2a;
                margin-bottom: 8px;
            }

            .live-badge {
                display: inline-block;
                padding: 5px 12px;
                font-size: 11px;
                color: #fff;
                background: linear-gradient(45deg, #7b0f2a, #d4af37);
                border-radius: 20px;
                animation: pulseBadge 1.8s infinite;
                margin-bottom: 10px;
            }

            @@keyframes pulseBadge {
                0% {
                    transform: scale(1);
                }

                50% {
                    transform: scale(1.08);
                }

                100% {
                    transform: scale(1);
                }
            }

            /* TEXT */
            .invite-text {
                font-family: 'Dancing Script', cursive;
                font-size: 16px;
                line-height: 1.7;
                color: #5a1a1a;
            }

            .names {
                font-family: 'Allura', cursive;
                font-size: 32px;
                font-weight: bolder;
                color: #7b0f2a;
                animation: glowIn 2s ease forwards;
                opacity: 0;
            }

            @@keyframes glowIn {
                from {
                    opacity: 0;
                    transform: translateY(10px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            /* SAVE CARD */
            .save-card {
                margin-top: 12px;
                padding: 12px;
                border-radius: 14px;
                background: rgba(255,255,255,0.35);
                border: 1px solid #d4af37;
                color: #7b0f2a;
                font-weight: bold;
            }

                .save-card span {
                    display: block;
                }

            .countdown-wrapper {
                display: flex;
                gap: 10px;
                justify-content: center;
                margin-top: 15px;
            }

            .count-box {
                text-align: center;
                flex: 1;
            }

            .flip-card {
                font-size: 20px;
                font-weight: bold;
                color: #7b0f2a;
                background: rgba(255,255,255,0.75);
                border-radius: 12px;
                padding: 12px 0;
                perspective: 1000px;
                transform-style: preserve-3d;
            }

            /* Flip animation */
            .flip {
                animation: flipAnim 0.6s ease;
            }

            @@keyframes flipAnim {
                0% {
                    transform: rotateX(0);
                }

                50% {
                    transform: rotateX(90deg);
                }

                100% {
                    transform: rotateX(0);
                }
            }

            .count-box label {
                font-size: 11px;
                color: #d4af37;
                margin-top: 5px;
                display: block;
            }

            /* BUTTON */
            .btn {
                display: block;
                margin-top: 12px;
                padding: 12px;
                background: #7b0f2a;
                color: #d4af37;
                border-radius: 12px;
                text-decoration: none;
            }

            /* HEART ICON */
            .heart {
                font-size: 18px;
            }

            .hearts {
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                pointer-events: none;
                z-index: 0;
                overflow: hidden;
            }

                .hearts span {
                    position: absolute;
                    bottom: -40px;
                    color: #ff4d6d;
                    font-size: 16px;
                    animation: floatUp 8s linear infinite;
                    opacity: 0.6;
                }

            @@keyframes floatUp {
                0% {
                    transform: translateY(0) scale(0.8);
                    opacity: 0;
                }

                20% {
                    opacity: 1;
                }

                100% {
                    transform: translateY(-120vh) scale(1.2);
                    opacity: 0;
                }
            }
    </style>
</head>

<body>

    <div class="hearts" id="hearts"></div>

    <div class="card">

        <img src="@Url.Content("~/Images/us.jpeg")" />

        <div class="content">

            <div class="live-badge">Engagement Invitation</div>
            @* <div class="live-badge">✨ LIVE INVITATION</div> *@

            <div class="invite-text">

                With the blessings of our families,<br><br>

                We warmly invite you to the<br>
                Engagement Ceremony of<br><br>

                <span class="names">Akshith<br /> &<br /> Sreekala</span><br><br>

                Your presence will make it special.<br><br>

                With Love 💖

            </div>

            <div class="save-card">
                <span>Sunday, 23rd August 2026</span>
                🕙 10:00 AM – 11:45 AM
            </div>

            <div class="countdown-wrapper">

                <div class="count-box">
                    <div class="flip-card" id="days">00</div>
                    <label>Days</label>
                </div>

                <div class="count-box">
                    <div class="flip-card" id="hours">00</div>
                    <label>Hours</label>
                </div>

                <div class="count-box">
                    <div class="flip-card" id="minutes">00</div>
                    <label>Minutes</label>
                </div>

                <div class="count-box">
                    <div class="flip-card" id="seconds">00</div>
                    <label>Seconds</label>
                </div>

            </div>

            <a class="btn" href="https://maps.app.goo.gl/kJaGm4EMwUGG6Fvv8">📍 View Venue</a>

            <audio id="music" loop>
                <source src="/music/music.mp3" type="audio/mpeg" />
            </audio>

        </div>
    </div>

    <script>
                        let eventDate = new Date("2026-08-23 10:00:00").getTime();

            function setFlip(id, value) {
                let el = document.getElementById(id);
                let newVal = String(value).padStart(2, '0');

                if (el.innerText !== newVal) {
                    el.classList.remove("flip");
                    void el.offsetWidth; // restart animation
                    el.innerText = newVal;
                    el.classList.add("flip");
                }
            }

            function updateCountdown() {
                let now = Date.now();
                let gap = eventDate - now;

                let days = Math.floor(gap / (1000 * 60 * 60 * 24));
                let hours = Math.floor((gap / (1000 * 60 * 60)) % 24);
                let minutes = Math.floor((gap / (1000 * 60)) % 60);
                let seconds = Math.floor((gap / 1000) % 60);

                setFlip("days", days);
                setFlip("hours", hours);
                setFlip("minutes", minutes);
                setFlip("seconds", seconds);
            }
                        function createHearts() {
                const container = document.getElementById("hearts");

                setInterval(() => {
                    let heart = document.createElement("span");
                    heart.innerHTML = "❤";

                    heart.style.left = Math.random() * 100 + "vw";
                    heart.style.fontSize = (12 + Math.random() * 18) + "px";
                    heart.style.animationDuration = (6 + Math.random() * 4) + "s";

                    container.appendChild(heart);

                    setTimeout(() => {
                        heart.remove();
                    }, 9000);

                }, 400);
            }

            createHearts();

            setInterval(updateCountdown, 1000);
            updateCountdown();

            /* MUSIC */
            window.addEventListener("click", function(){
                document.getElementById("music").play();
            }, {once:true});
    </script>

</body>
</html>